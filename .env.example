APP_NAME=SmartSuper
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

HASH_DRIVER=argon
ARGON_MEMORY=65536
ARGON_THREADS=2
ARGON_TIME=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
CONTACTO_EMAIL=smartsuper.dev@gmail.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CATALOGO_EXTERNO_SCHEDULER_ENABLED=false
CATALOGO_EXTERNO_POWERSHELL_BINARY='C:/Program Files/PowerShell/7/pwsh.exe'
CATALOGO_EXTERNO_PROCESS_TIMEOUT=3600

CATALOGO_EXTERNO_MERCADONA_ENABLED=false
CATALOGO_EXTERNO_MERCADONA_POSTAL_CODE=
CATALOGO_EXTERNO_MERCADONA_WAREHOUSE_ID=
CATALOGO_EXTERNO_MERCADONA_COOKIE=
CATALOGO_EXTERNO_MERCADONA_CUSTOMER_DEVICE_ID=
CATALOGO_EXTERNO_MERCADONA_X_VERSION=
CATALOGO_EXTERNO_MERCADONA_IDS_FILE="scripts/scrapers/supermercados/mercadona_category_ids.txt"
CATALOGO_EXTERNO_MERCADONA_OUTPUT_DIR="storage/app/scraping/mercadona"

CATALOGO_EXTERNO_CONSUM_ENABLED=false
CATALOGO_EXTERNO_CONSUM_POSTAL_CODE=
CATALOGO_EXTERNO_CONSUM_WAREHOUSE_ID=
CATALOGO_EXTERNO_CONSUM_CATEGORIES_FILE="scripts/scrapers/supermercados/consum_categories.txt"
CATALOGO_EXTERNO_CONSUM_OUTPUT_DIR="storage/app/scraping/consum"
CATALOGO_EXTERNO_CONSUM_LIMIT=20
CATALOGO_EXTERNO_CONSUM_ORDER_BY_ID=5
CATALOGO_EXTERNO_CONSUM_X_TOL_ZONE=0
CATALOGO_EXTERNO_CONSUM_X_TOL_CHANNEL=1
CATALOGO_EXTERNO_CONSUM_X_TOL_LOCALE=es
CATALOGO_EXTERNO_CONSUM_X_TOL_APP=shop-front
CATALOGO_EXTERNO_CONSUM_X_TOL_SHIPPING_ZONE=0D
CATALOGO_EXTERNO_CONSUM_X_TOL_CURRENCY=EUR

CATALOGO_EXTERNO_CARREFOUR_ENABLED=false
CATALOGO_EXTERNO_CARREFOUR_POSTAL_CODE=
CATALOGO_EXTERNO_CARREFOUR_SALE_POINT=
CATALOGO_EXTERNO_CARREFOUR_DELIVERY_TYPE=A_DOMICILIO
CATALOGO_EXTERNO_CARREFOUR_COOKIE_FILE="scripts/scrapers/supermercados/carrefour_cookie.txt"
CATALOGO_EXTERNO_CARREFOUR_CATEGORIES_FILE="scripts/scrapers/supermercados/carrefour_categories.txt"
CATALOGO_EXTERNO_CARREFOUR_OUTPUT_DIR="storage/app/scraping/carrefour"
CATALOGO_EXTERNO_CARREFOUR_PAGE_SIZE=24
CATALOGO_EXTERNO_CARREFOUR_MAX_RETRIES=3
CATALOGO_EXTERNO_CARREFOUR_RETRY_DELAY_SECONDS=3

VITE_APP_NAME="${APP_NAME}"
